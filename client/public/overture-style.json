{
  "version": 8,
  "name": "overture-source-type",
  "sources": {
    "overture": {
      "type": "geojson",
      "data": "/overture.json"
    }
  },
  "layers": [
    {
      "id": "overture-fill",
      "type": "fill",
      "source": "overture",
      "paint": {
        "fill-color": [
          "match",
          ["get", "source_type"],
          "my",  "#2ca02c",
          "osm", "#1f77b4",
          "ml",  "#ff7f0e",
          "#888888"
        ],
        "fill-opacity": 0.6,
        "fill-outline-color": "#222222"
      }
    }
  ]
}
